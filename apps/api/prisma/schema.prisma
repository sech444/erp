// ─────────────────────────────────────────────────────────────────────────────
//  ERP COMPLETE DATABASE SCHEMA  — All 34 modules from requirements
//  Construction / Waterproofing / Technical Services Company — UAE
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
//  ENUMS
// ═════════════════════════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  DIRECTOR
  MANAGER
  SALES_TEAM
  ACCOUNTANT
  PURCHASE_DEPT
  HR_DEPT
  STORE_KEEPER
  SITE_SUPERVISOR
  TECHNICIAN
  SUB_CONTRACTOR
  CLIENT_PORTAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTATION_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  REFERRAL
  WEBSITE
  COLD_CALL
  EXHIBITION
  SOCIAL_MEDIA
  TENDER
  OTHER
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderStatus {
  DRAFT
  ISSUED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkOrderType {
  INTERNAL
  SUBCONTRACTOR
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RETURN
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  UNPAID
  MATERNITY
  PATERNITY
}

enum AlertType {
  LOW_STOCK
  VISA_EXPIRY
  PASSPORT_EXPIRY
  INSURANCE_EXPIRY
  PAYMENT_DUE
  PROJECT_DELAY
  DOCUMENT_EXPIRY
  VEHICLE_SERVICE
  VEHICLE_INSURANCE
  PETTY_CASH_LOW
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceType {
  PROFORMA
  TAX_INVOICE
  CREDIT_NOTE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum VehicleStatus {
  ACTIVE
  UNDER_MAINTENANCE
  INACTIVE
}

enum DocumentCategory {
  CONTRACT
  INVOICE
  LPO
  DRAWING
  EMPLOYEE_DOC
  PROJECT_PHOTO
  WARRANTY
  INSURANCE
  OTHER
}

enum BOQStatus {
  DRAFT
  APPROVED
  REVISED
}

enum SiteReportStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum PettyCashStatus {
  PENDING
  APPROVED
  REJECTED
  REIMBURSED
}

// ═════════════════════════════════════════════════════════════════════════════
//  AUTH & USERS  (Module 2 — User Roles, Module 32 — Security & Audit)
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee             Employee?
  createdLeads         Lead[]               @relation("CreatedByUser")
  assignedLeads        Lead[]               @relation("AssignedToUser")
  createdQuotations    Quotation[]
  stockMovements       StockMovement[]
  purchaseOrders       PurchaseOrder[]
  approvedPayrolls     Payroll[]            @relation("ApprovedBy")
  activityLogs         ActivityLog[]
  refreshTokens        RefreshToken[]
  siteReports          SiteProgressReport[]
  workOrders           WorkOrder[]          @relation("CreatedWorkOrders")
  journalEntries       JournalEntry[]
  pettyCashRequests    PettyCashRequest[]   @relation("RequestedBy")
  pettyCashApprovals   PettyCashRequest[]   @relation("ApprovedByUser")
  uploadedDocuments    Document[]
  notifications        Notification[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@map("activity_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
//  CRM  (Module 4 — CRM Module)
// ═════════════════════════════════════════════════════════════════════════════

model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  portalAccess  Boolean  @default(false)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads       Lead[]
  quotations  Quotation[]
  projects    Project[]
  invoices    Invoice[]
  retentions  Retention[]

  @@map("clients")
}

model Lead {
  id             String     @id @default(cuid())
  title          String
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id])
  contactName    String
  contactEmail   String?
  contactPhone   String?
  source         LeadSource @default(OTHER)
  status         LeadStatus @default(NEW)
  estimatedValue Decimal?   @db.Decimal(14, 2)
  notes          String?
  lostReason     String?
  followUpDate   DateTime?
  assignedToId   String?
  assignedTo     User?      @relation("AssignedToUser", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User       @relation("CreatedByUser", fields: [createdById], references: [id])
  wonAt          DateTime?
  lostAt         DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  activities LeadActivity[]
  quotations Quotation[]

  @@index([status])
  @@index([assignedToId])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  notes     String
  createdAt DateTime @default(now())

  @@map("lead_activities")
}

// ═════════════════════════════════════════════════════════════════════════════
//  SALES & QUOTATION  (Module 5)
// ═════════════════════════════════════════════════════════════════════════════

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  status          QuotationStatus @default(DRAFT)
  scopeOfWork     String?
  validUntil      DateTime?
  paymentTerms    Json?
  retentionPct    Decimal?        @db.Decimal(5, 2)
  subtotal        Decimal         @db.Decimal(14, 2)
  vatPct          Decimal         @default(5) @db.Decimal(5, 2)
  vatAmount       Decimal         @db.Decimal(14, 2)
  totalAmount     Decimal         @db.Decimal(14, 2)
  notes           String?
  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])
  sentAt          DateTime?
  viewedAt        DateTime?
  pdfUrl          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items    QuotationItem[]
  projects Project[]

  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  materialId  String?
  material    Material? @relation(fields: [materialId], references: [id])
  description String
  unit        String
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(12, 2)
  type        String    @default("MATERIAL")
  sortOrder   Int       @default(0)

  @@map("quotation_items")
}

// ═════════════════════════════════════════════════════════════════════════════
//  BOQ MANAGEMENT  (Modules 6 & 7 — BOQ + AI Estimation)
// ═════════════════════════════════════════════════════════════════════════════

model BOQ {
  id            String    @id @default(cuid())
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  status        BOQStatus @default(DRAFT)
  version       Int       @default(1)
  aiEstimated   Boolean   @default(false)
  aiConfidence  Decimal?  @db.Decimal(5, 2)
  sourceFileUrl String?
  totalMaterial Decimal   @default(0) @db.Decimal(14, 2)
  totalLabour   Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @default(0) @db.Decimal(14, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items BOQItem[]

  @@map("boqs")
}

model BOQItem {
  id               String    @id @default(cuid())
  boqId            String
  boq              BOQ       @relation(fields: [boqId], references: [id], onDelete: Cascade)
  materialId       String?
  material         Material? @relation(fields: [materialId], references: [id])
  description      String
  unit             String
  quantity         Decimal   @db.Decimal(12, 3)
  unitPrice        Decimal   @db.Decimal(12, 2)
  totalPrice       Decimal   @db.Decimal(12, 2)
  type             String    @default("MATERIAL")
  sortOrder        Int       @default(0)
  aiSuggestedPrice Decimal?  @db.Decimal(12, 2)
  aiPriceSource    String?

  @@map("boq_items")
}

// Drawing Analysis results — Module 8
model DrawingAnalysis {
  id              String   @id @default(cuid())
  projectId       String?
  fileName        String
  fileUrl         String
  status          String   @default("PROCESSING") // PROCESSING | COMPLETED | FAILED
  // AI identified areas (JSON): [{type:"WATERPROOFING", areaSqm:120.5}, ...]
  identifiedAreas Json?
  totalAreaSqm    Decimal? @db.Decimal(10, 2)
  // AI suggested materials (JSON)
  materialSuggestions Json?
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@map("drawing_analyses")
}

// ═════════════════════════════════════════════════════════════════════════════
//  PROJECT MANAGEMENT  (Modules 9 & 10)
// ═════════════════════════════════════════════════════════════════════════════

model Project {
  id              String        @id @default(cuid())
  projectCode     String        @unique
  name            String
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  quotationId     String?
  quotation       Quotation?    @relation(fields: [quotationId], references: [id])
  status          ProjectStatus @default(PLANNING)
  location        String?
  description     String?
  startDate       DateTime?
  completionDate  DateTime?
  actualEndDate   DateTime?
  projectValue    Decimal       @db.Decimal(14, 2)
  budgetMaterial  Decimal       @default(0) @db.Decimal(14, 2)
  budgetLabour    Decimal       @default(0) @db.Decimal(14, 2)
  budgetEquipment Decimal       @default(0) @db.Decimal(14, 2)
  budgetOther     Decimal       @default(0) @db.Decimal(14, 2)
  actualMaterial  Decimal       @default(0) @db.Decimal(14, 2)
  actualLabour    Decimal       @default(0) @db.Decimal(14, 2)
  actualEquipment Decimal       @default(0) @db.Decimal(14, 2)
  actualOther     Decimal       @default(0) @db.Decimal(14, 2)
  progressPct     Decimal       @default(0) @db.Decimal(5, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  boqs           BOQ[]
  workOrders     WorkOrder[]
  siteReports    SiteProgressReport[]
  invoices       Invoice[]
  retentions     Retention[]
  documents      Document[]
  stockMovements StockMovement[]

  @@index([status])
  @@map("projects")
}

// ═════════════════════════════════════════════════════════════════════════════
//  WORK ORDERS  (Module 11)
// ═════════════════════════════════════════════════════════════════════════════

model WorkOrder {
  id              String          @id @default(cuid())
  woNumber        String          @unique
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])
  type            WorkOrderType   @default(INTERNAL)
  subcontractorId String?
  subcontractor   Subcontractor?  @relation(fields: [subcontractorId], references: [id])
  status          WorkOrderStatus @default(DRAFT)
  title           String
  description     String?
  scopeOfWork     String?
  startDate       DateTime?
  endDate         DateTime?
  amount          Decimal?        @db.Decimal(14, 2)
  notes           String?
  createdById     String
  createdBy       User            @relation("CreatedWorkOrders", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  documents Document[]

  @@map("work_orders")
}

// ═════════════════════════════════════════════════════════════════════════════
//  SITE PROGRESS REPORTING  (Module 12)
// ═════════════════════════════════════════════════════════════════════════════

model SiteProgressReport {
  id               String           @id @default(cuid())
  projectId        String
  project          Project          @relation(fields: [projectId], references: [id])
  reportDate       DateTime         @db.Date
  status           SiteReportStatus @default(DRAFT)
  workProgress     String
  progressPct      Decimal          @db.Decimal(5, 2)
  manpowerCount    Int              @default(0)
  materialsUsed    Json?
  issues           String?
  notes            String?
  weatherCondition String?
  submittedById    String
  submittedBy      User             @relation(fields: [submittedById], references: [id])
  submittedAt      DateTime?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  photos Document[] @relation("ReportPhotos")

  @@index([projectId, reportDate])
  @@map("site_progress_reports")
}

// ═════════════════════════════════════════════════════════════════════════════
//  INVENTORY  (Module 13)
// ═════════════════════════════════════════════════════════════════════════════

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  paymentTerms  String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  materials        Material[]
  purchaseOrders   PurchaseOrder[]
  supplierPayments SupplierPayment[]

  @@map("suppliers")
}

model MaterialCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  materials Material[]

  @@map("material_categories")
}

model Material {
  id            String            @id @default(cuid())
  sku           String            @unique
  name          String
  description   String?
  unit          String
  categoryId    String?
  category      MaterialCategory? @relation(fields: [categoryId], references: [id])
  supplierId    String?
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  unitPrice     Decimal           @db.Decimal(12, 2)
  currentStock  Decimal           @default(0) @db.Decimal(12, 3)
  minStockLevel Decimal           @default(0) @db.Decimal(12, 3)
  maxStockLevel Decimal?          @db.Decimal(12, 3)
  reorderPoint  Decimal           @default(0) @db.Decimal(12, 3)
  location      String?
  imageUrl      String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  quotationItems     QuotationItem[]
  boqItems           BOQItem[]
  alerts             Alert[]

  @@index([sku])
  @@map("materials")
}

model StockMovement {
  id              String            @id @default(cuid())
  materialId      String
  material        Material          @relation(fields: [materialId], references: [id])
  projectId       String?
  project         Project?          @relation(fields: [projectId], references: [id])
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  unitPrice       Decimal?          @db.Decimal(12, 2)
  totalValue      Decimal?          @db.Decimal(12, 2)
  reference       String?
  notes           String?
  fromLocation    String?
  toLocation      String?
  performedById   String
  performedBy     User              @relation(fields: [performedById], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  createdAt       DateTime          @default(now())

  @@index([materialId])
  @@index([projectId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ═════════════════════════════════════════════════════════════════════════════
//  PURCHASE MANAGEMENT  (Module 14)
// ═════════════════════════════════════════════════════════════════════════════

model PurchaseRequest {
  id          String                @id @default(cuid())
  prNumber    String                @unique
  projectId   String?
  requestedBy String
  notes       String?
  status      String                @default("PENDING")
  createdAt   DateTime              @default(now())
  items       PurchaseRequestItem[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  materialId        String?
  description       String
  quantity          Decimal         @db.Decimal(12, 3)
  unit              String
  urgency           String          @default("NORMAL")

  @@map("purchase_request_items")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  status          PurchaseOrderStatus @default(DRAFT)
  deliveryDate    DateTime?
  deliveryAddress String?
  notes           String?
  subtotal        Decimal             @db.Decimal(14, 2)
  vatAmount       Decimal             @default(0) @db.Decimal(14, 2)
  totalAmount     Decimal             @db.Decimal(14, 2)
  createdById     String
  createdBy       User                @relation(fields: [createdById], references: [id])
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items            PurchaseOrderItem[]
  stockMovements   StockMovement[]
  supplierPayments SupplierPayment[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialId      String?
  material        Material?     @relation(fields: [materialId], references: [id])
  description     String
  quantity        Decimal       @db.Decimal(12, 3)
  unitPrice       Decimal       @db.Decimal(12, 2)
  totalPrice      Decimal       @db.Decimal(12, 2)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 3)

  @@map("purchase_order_items")
}

model SupplierPayment {
  id              String         @id @default(cuid())
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  amount          Decimal        @db.Decimal(14, 2)
  method          PaymentMethod
  reference       String?
  notes           String?
  paidAt          DateTime
  createdAt       DateTime       @default(now())

  @@map("supplier_payments")
}

// ═════════════════════════════════════════════════════════════════════════════
//  SUBCONTRACTOR MANAGEMENT  (Module 16)
// ═════════════════════════════════════════════════════════════════════════════

model Subcontractor {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  specialty     String?
  contractStart DateTime?
  contractEnd   DateTime?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workOrders WorkOrder[]
  payments   SubcontractorPayment[]
  documents  Document[]

  @@map("subcontractors")
}

model SubcontractorPayment {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod
  reference       String?
  description     String?
  paidAt          DateTime
  createdAt       DateTime      @default(now())

  @@map("subcontractor_payments")
}

// ═════════════════════════════════════════════════════════════════════════════
//  HR  (Modules 17, 18, 19, 20)
// ═════════════════════════════════════════════════════════════════════════════

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String?    @unique
  createdAt DateTime   @default(now())
  employees Employee[]

  @@map("departments")
}

model Employee {
  id                 String           @id @default(cuid())
  employeeCode       String           @unique
  userId             String?          @unique
  user               User?            @relation(fields: [userId], references: [id])
  firstName          String
  lastName           String
  email              String?
  phone              String?
  departmentId       String?
  department         Department?      @relation(fields: [departmentId], references: [id])
  position           String
  status             EmploymentStatus @default(ACTIVE)
  joinDate           DateTime
  terminationDate    DateTime?
  passportNumber     String?
  passportExpiry     DateTime?
  visaNumber         String?
  visaExpiry         DateTime?
  emiratesId         String?
  emiratesIdExpiry   DateTime?
  laborCardExpiry    DateTime?
  insuranceExpiry    DateTime?
  medicalExpiry      DateTime?
  basicSalary        Decimal          @db.Decimal(12, 2)
  housingAllowance   Decimal          @default(0) @db.Decimal(12, 2)
  transportAllowance Decimal          @default(0) @db.Decimal(12, 2)
  otherAllowances    Decimal          @default(0) @db.Decimal(12, 2)
  overtimeRate       Decimal          @default(0) @db.Decimal(8, 2)
  visaCost           Decimal?         @db.Decimal(12, 2)
  medicalCost        Decimal?         @db.Decimal(12, 2)
  insuranceCost      Decimal?         @db.Decimal(12, 2)
  recruitmentCost    Decimal?         @db.Decimal(12, 2)
  photoUrl           String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  payrollItems       PayrollItem[]
  performanceReviews PerformanceReview[]

  @@index([status])
  @@map("employees")
}

model Attendance {
  id            String           @id @default(cuid())
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id])
  date          DateTime         @db.Date
  status        AttendanceStatus @default(PRESENT)
  checkIn       DateTime?
  checkOut      DateTime?
  latitude      Decimal?         @db.Decimal(10, 7)
  longitude     Decimal?         @db.Decimal(10, 7)
  overtimeHours Decimal          @default(0) @db.Decimal(5, 2)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

model LeaveRequest {
  id              String      @id @default(cuid())
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  type            LeaveType
  startDate       DateTime    @db.Date
  endDate         DateTime    @db.Date
  totalDays       Int
  reason          String?
  status          LeaveStatus @default(PENDING)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("leave_requests")
}

model Payroll {
  id              String        @id @default(cuid())
  periodMonth     Int
  periodYear      Int
  status          PayrollStatus @default(DRAFT)
  totalBasic      Decimal       @db.Decimal(14, 2)
  totalAllowances Decimal       @db.Decimal(14, 2)
  totalOvertime   Decimal       @db.Decimal(14, 2)
  totalDeductions Decimal       @db.Decimal(14, 2)
  totalNet        Decimal       @db.Decimal(14, 2)
  approvedById    String?
  approvedBy      User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items PayrollItem[]

  @@unique([periodMonth, periodYear])
  @@map("payrolls")
}

model PayrollItem {
  id                 String   @id @default(cuid())
  payrollId          String
  payroll            Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id])
  basicSalary        Decimal  @db.Decimal(12, 2)
  housingAllowance   Decimal  @db.Decimal(12, 2)
  transportAllowance Decimal  @db.Decimal(12, 2)
  otherAllowances    Decimal  @db.Decimal(12, 2)
  overtimeHours      Decimal  @db.Decimal(5, 2)
  overtimePay        Decimal  @db.Decimal(12, 2)
  deductions         Decimal  @db.Decimal(12, 2)
  deductionNotes     String?
  netSalary          Decimal  @db.Decimal(12, 2)
  payslipUrl         String?

  @@map("payroll_items")
}

model PerformanceReview {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  reviewDate   DateTime @db.Date
  reviewPeriod String
  kpis         Json
  overallScore Decimal  @db.Decimal(4, 2)
  strengths    String?
  improvements String?
  managerNotes String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("performance_reviews")
}

// ═════════════════════════════════════════════════════════════════════════════
//  VEHICLE MANAGEMENT  (Module 21)
// ═════════════════════════════════════════════════════════════════════════════

model Vehicle {
  id                 String        @id @default(cuid())
  plateNumber        String        @unique
  make               String
  model              String
  year               Int
  type               String
  status             VehicleStatus @default(ACTIVE)
  assignedTo         String?
  insuranceExpiry    DateTime?
  registrationExpiry DateTime?
  lastServiceDate    DateTime?
  nextServiceDate    DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  fuelLogs        VehicleFuelLog[]
  maintenanceLogs VehicleMaintenanceLog[]
  salikLogs       VehicleSalikLog[]

  @@map("vehicles")
}

model VehicleFuelLog {
  id           String   @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  date         DateTime @db.Date
  litres       Decimal  @db.Decimal(8, 2)
  costPerLitre Decimal  @db.Decimal(6, 3)
  totalCost    Decimal  @db.Decimal(10, 2)
  odometer     Int?
  notes        String?
  createdAt    DateTime @default(now())

  @@map("vehicle_fuel_logs")
}

model VehicleMaintenanceLog {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  date        DateTime @db.Date
  type        String
  description String
  cost        Decimal  @db.Decimal(10, 2)
  garage      String?
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("vehicle_maintenance_logs")
}

model VehicleSalikLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(8, 2)
  gateId    String?
  createdAt DateTime @default(now())

  @@map("vehicle_salik_logs")
}

// ═════════════════════════════════════════════════════════════════════════════
//  PETTY CASH  (Module 22)
// ═════════════════════════════════════════════════════════════════════════════

model PettyCashFund {
  id        String   @id @default(cuid())
  name      String
  balance   Decimal  @db.Decimal(12, 2)
  maxLimit  Decimal  @db.Decimal(12, 2)
  custodian String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requests PettyCashRequest[]

  @@map("petty_cash_funds")
}

model PettyCashRequest {
  id              String          @id @default(cuid())
  fundId          String
  fund            PettyCashFund   @relation(fields: [fundId], references: [id])
  category        String
  description     String
  amount          Decimal         @db.Decimal(10, 2)
  receiptUrl      String?
  status          PettyCashStatus @default(PENDING)
  requestedById   String
  requestedBy     User            @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?           @relation("ApprovedByUser", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  expenseDate     DateTime        @db.Date
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@map("petty_cash_requests")
}

// ═════════════════════════════════════════════════════════════════════════════
//  ACCOUNTING  (Modules 23–27)
// ═════════════════════════════════════════════════════════════════════════════

model Account {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  type        AccountType
  parentId    String?
  parent      Account?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]   @relation("AccountHierarchy")
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  debitLines  JournalLine[] @relation("DebitAccount")
  creditLines JournalLine[] @relation("CreditAccount")

  @@map("accounts")
}

model JournalEntry {
  id          String             @id @default(cuid())
  entryNumber String             @unique
  date        DateTime           @db.Date
  description String
  reference   String?
  status      JournalEntryStatus @default(DRAFT)
  createdById String
  createdBy   User               @relation(fields: [createdById], references: [id])
  postedAt    DateTime?
  createdAt   DateTime           @default(now())

  lines JournalLine[]

  @@index([date])
  @@map("journal_entries")
}

model JournalLine {
  id          String       @id @default(cuid())
  journalId   String
  journal     JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  debitAccId  String?
  debitAcc    Account?     @relation("DebitAccount", fields: [debitAccId], references: [id])
  creditAccId String?
  creditAcc   Account?     @relation("CreditAccount", fields: [creditAccId], references: [id])
  amount      Decimal      @db.Decimal(14, 2)
  description String?
  sortOrder   Int          @default(0)

  @@map("journal_lines")
}

// Invoices & AR
model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  type          InvoiceType   @default(TAX_INVOICE)
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @db.Date
  dueDate       DateTime      @db.Date
  subtotal      Decimal       @db.Decimal(14, 2)
  vatPct        Decimal       @default(5) @db.Decimal(5, 2)
  vatAmount     Decimal       @db.Decimal(14, 2)
  retentionAmt  Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal       @db.Decimal(14, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  notes         String?
  pdfUrl        String?
  sentAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  @@map("invoice_items")
}

// Retention — Module 25
model Retention {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  invoiceValue Decimal  @db.Decimal(14, 2)
  retentionPct Decimal  @db.Decimal(5, 2)
  retentionAmt Decimal  @db.Decimal(14, 2)
  released     Boolean  @default(false)
  releasedAt   DateTime?
  releasedAmt  Decimal? @db.Decimal(14, 2)
  dueDate      DateTime?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@map("retentions")
}

// Payments — Module 26
model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(14, 2)
  method        PaymentMethod
  reference     String?
  notes         String?
  paidAt        DateTime
  bankAccountId String?
  bankAccount   BankAccount?  @relation(fields: [bankAccountId], references: [id])
  createdAt     DateTime      @default(now())

  @@map("payments")
}

// Bank Integration — Module 27
model BankAccount {
  id             String   @id @default(cuid())
  bankName       String
  accountName    String
  accountNumber  String
  iban           String?
  currency       String   @default("AED")
  currentBalance Decimal  @default(0) @db.Decimal(14, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions BankTransaction[]
  payments     Payment[]

  @@map("bank_accounts")
}

model BankTransaction {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  date          DateTime    @db.Date
  description   String
  amount        Decimal     @db.Decimal(14, 2)
  balance       Decimal?    @db.Decimal(14, 2)
  reference     String?
  isReconciled  Boolean     @default(false)
  reconciledAt  DateTime?
  createdAt     DateTime    @default(now())

  @@index([bankAccountId, date])
  @@map("bank_transactions")
}

// VAT — Module 24
model VATReturn {
  id          String   @id @default(cuid())
  period      String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  outputVAT   Decimal  @db.Decimal(14, 2)
  inputVAT    Decimal  @db.Decimal(14, 2)
  netVAT      Decimal  @db.Decimal(14, 2)
  status      String   @default("DRAFT")
  submittedAt DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("vat_returns")
}

// ═════════════════════════════════════════════════════════════════════════════
//  DOCUMENT MANAGEMENT  (Module 30)
// ═════════════════════════════════════════════════════════════════════════════

model Document {
  id              String           @id @default(cuid())
  name            String
  category        DocumentCategory
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  projectId       String?
  project         Project?         @relation(fields: [projectId], references: [id])
  workOrderId     String?
  workOrder       WorkOrder?       @relation(fields: [workOrderId], references: [id])
  subcontractorId String?
  subcontractor   Subcontractor?   @relation(fields: [subcontractorId], references: [id])
  siteReportId    String?
  siteReport      SiteProgressReport? @relation("ReportPhotos", fields: [siteReportId], references: [id])
  uploadedById    String
  uploadedBy      User             @relation(fields: [uploadedById], references: [id])
  notes           String?
  expiryDate      DateTime?
  createdAt       DateTime         @default(now())

  @@index([category])
  @@index([projectId])
  @@map("documents")
}

// ═════════════════════════════════════════════════════════════════════════════
//  NOTIFICATIONS  (Module 31)
// ═════════════════════════════════════════════════════════════════════════════

model Alert {
  id         String    @id @default(cuid())
  type       AlertType
  title      String
  message    String
  isRead     Boolean   @default(false)
  entityId   String?
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([isRead])
  @@index([type])
  @@map("alerts")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ═════════════════════════════════════════════════════════════════════════════
//  WARRANTY / CLIENT PORTAL  (Module 29)
// ═════════════════════════════════════════════════════════════════════════════

model WarrantyCertificate {
  id         String   @id @default(cuid())
  projectId  String
  clientId   String
  certNumber String   @unique
  issueDate  DateTime @db.Date
  expiryDate DateTime @db.Date
  scope      String?
  terms      String?
  pdfUrl     String?
  createdAt  DateTime @default(now())

  @@map("warranty_certificates")
}

