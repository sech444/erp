# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://erp:erp_secret@localhost:5432/erp_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_in_production_use_256bit_random
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── API ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1

# ─── File Storage (AWS S3 / DO Spaces) ──────────────────────
STORAGE_PROVIDER=local          # local | s3 | spaces
STORAGE_BUCKET=erp-uploads
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=               # For DigitalOcean Spaces

# ─── Email (SendGrid) ───────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=ERP System

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=ERP System
